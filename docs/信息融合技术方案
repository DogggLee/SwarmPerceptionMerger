    "sensor_params":                    
        {
            "fov": [hfov, vfov],        # 传感器视场角
            "range": range,             # 传感器有效感知范围
            "K": K;                     # 相机内参矩阵
            "resolution": [H, W]        # 图像分辨率             
        }    
    "detection": {
        "class_id": 0,                  # 类别ID
        "position": [x, y, z],          # 目标全局位置（东北天坐标）
        "velocity": [vx, vy, vz],       # 目标全局速度（东北天坐标）
        "track_id": 0,                  # 目标跟踪ID
        "bbox": [x, y, w, h]            # 目标2D BBox （归一化坐标）
